# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash

# Retrieval / infra (optional — sensible local defaults are used if unset)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=clinical_docs
VECTOR_STORE_DIR=data/vector_store
USE_LOCAL_BM25=0
USE_IN_MEMORY_STORE=0
USE_HASHING_EMBEDDER=0
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_KEYWORD_WEIGHT=0.4
